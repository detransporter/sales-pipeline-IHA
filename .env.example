# ── E-post (skicka mejl direkt från appen via Gmail SMTP) ──────────────
# SMTP_PASS = Gmail APP-LÖSENORD (16 tecken), INTE ditt vanliga lösenord.
# Skapas på myaccount.google.com → Säkerhet → Tvåstegsverifiering → App-lösenord.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din.adress@gmail.com
SMTP_PASS=app_losenord_16_tecken
