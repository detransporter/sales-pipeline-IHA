# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud → din app → Settings → Secrets → klistra in detta (ifyllt).
# Hämta de riktiga värdena från din lokala .env-fil. Ändra INTE nyckelnamnen.
# ─────────────────────────────────────────────────────────────────────────────

# Inloggning (skyddar appen online). Sätt en delad kod ni två använder.
APP_PASSWORD = "valj-en-hemlig-kod"

# AI (obligatoriskt)
ANTHROPIC_API_KEY = "sk-ant-..."

# Databas (obligatoriskt) — samma projekt som lokalt
SUPABASE_URL = "https://xxx.supabase.co"
SUPABASE_KEY = "eyJ..."
SUPABASE_SCHEMA = "sales_chief"

# Bolagssökning (valfritt — utan denna funkar gratis hemsidegissning ändå)
APIFY_TOKEN = "apify_api_..."
APIFY_MAPS_ACTOR = "compass/crawler-google-places"

# Utgående mejl via Gmail (valfritt — krävs för att skicka mejl från appen)
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "din.adress@gmail.com"
SMTP_PASS = "xxxx xxxx xxxx xxxx"   # Gmail app-lösenord (16 tecken)
SMTP_FROM_NAME = "David Leifsson"

# Inkommande mejlsvar (valfritt)
IMAP_HOST = "imap.gmail.com"
IMAP_PORT = "993"

# Bolagsverket API (valfritt)
BV_CLIENT_ID = "..."
BV_CLIENT_SECRET = "..."
BV_TOKEN_URL = "..."
BV_API_BASE = "..."
BV_SCOPE = "..."

# Telegram-notiser (valfritt)
TELEGRAM_BOT_TOKEN = "..."
TELEGRAM_CHAT_ID = "..."
